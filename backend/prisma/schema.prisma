generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int       @id @default(autoincrement())
  email            String    @unique
  name             String?
  password         String
  refreshToken     String?
  fcmToken         String?
  role             Role      @default(renter)

  bookings           Booking[]
  ownerBookings      Booking[] @relation("OwnerBookings")
  sentMessages       Message[] @relation("SentMessages")
  receivedMessages   Message[] @relation("ReceivedMessages")
  receivedNotifications Notification[] @relation("ReceivedNotifications")
  sentNotifications   Notification[] @relation("SentNotifications")
  inquiries          Inquiry[]
  drivers          Driver[]
  cars             Car[]
  reviews          Review[]
  wishlistItems    Wishlist[]
  auditLogs        AuditLog[]
  dailyReports     DailyReport[]
  profile          Profile?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Profile {
  id             Int      @id
  user           User     @relation(fields: [id], references: [id], onDelete: Cascade)
  full_name      String?
  phone          String?  @unique
  avatar_url     String?
  nrc            String?
  nrc_url        String?
  gender         String?
  postal_code    String?
  location       String?
  is_active      Boolean  @default(true)
  is_blacklist   Boolean  @default(false)
  expo_push_token String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Car {
  id           Int       @id @default(autoincrement())
  ownerId      Int?
  owner        User?     @relation(fields: [ownerId], references: [id])
  brand        String
  model        String
  year         Int
  car_type     String?
  car_number   String?   @unique
  pricePerDay  Float
  seats        Int?
  has_ac       Boolean?  @default(false)
  status       String?   @default("Available")
  postal_code  String?
  location     String?
  description  String?
  isAvailable  Boolean   @default(true)

  bookings     Booking[]
  carImages    CarImage[]
  reviews      Review[]
  wishlistItems Wishlist[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model CarImage {
  id         Int      @id @default(autoincrement())
  carId      Int
  car        Car      @relation(fields: [carId], references: [id])
  image_url  String
  is_primary Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Driver {
  id             Int       @id @default(autoincrement())
  ownerId        Int
  owner          User      @relation(fields: [ownerId], references: [id])
  name           String
  phone          String
  photo_url      String?
  license_img_url String?
  gender         String?
  status         String?   @default("available")
  license_number String?
  nrc            String?
  postal_code    String?
  location       String?
  leave          Boolean   @default(false)

  bookings       Booking[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Booking {
  id              Int      @id @default(autoincrement())
  startDate       DateTime
  endDate         DateTime
  totalPrice      Float
  status          BookingStatus @default(PENDING)
  pickupTime      String?
  dropoffTime     String?
  pickupLocation  String?
  dropoffLocation String?
  note            String?
  isRead          Boolean  @default(false)

  userId          Int
  user            User     @relation(fields: [userId], references: [id])

  ownerId         Int?
  owner           User?    @relation("OwnerBookings", fields: [ownerId], references: [id])

  carId           Int
  car             Car      @relation(fields: [carId], references: [id])

  driverId        Int?
  driver          Driver?  @relation(fields: [driverId], references: [id])

  notifications   Notification[]
  inquiries       Inquiry[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Review {
  id        Int      @id @default(autoincrement())
  carId     Int
  car       Car      @relation(fields: [carId], references: [id])
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
}

model Wishlist {
  id          Int      @id @default(autoincrement())
  customerId  Int
  customer    User     @relation(fields: [customerId], references: [id])
  carId       Int
  car         Car      @relation(fields: [carId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([customerId, carId])
}

model Message {
  id         Int      @id @default(autoincrement())
  content    String
  isRead     Boolean  @default(false)

  senderId   Int
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])

  receiverId Int
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])

  createdAt  DateTime @default(now())
}

model Notification {
  id          Int      @id @default(autoincrement())
  title       String
  body        String
  type        String
  isRead      Boolean  @default(false)
  referenceId String?

  userId      Int
  user        User     @relation("ReceivedNotifications", fields: [userId], references: [id])

  senderId    Int?
  sender      User?    @relation("SentNotifications", fields: [senderId], references: [id])

  bookingId   Int?
  booking     Booking? @relation(fields: [bookingId], references: [id])

  createdAt   DateTime @default(now())
}

model Inquiry {
  id              Int      @id @default(autoincrement())
  submittedUserId Int
  submittedUser   User     @relation(fields: [submittedUserId], references: [id])
  type            String
  content         String
  status          String   @default("opened")
  bookingId       Int?
  booking         Booking? @relation(fields: [bookingId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  table_name String
  record_id  Int
  action     String
  old_value  Json?
  new_value  Json?
  changed_by Int?
  changedBy  User?    @relation(fields: [changed_by], references: [id])
  createdAt  DateTime @default(now())
}

model DailyReport {
  id              Int      @id @default(autoincrement())
  ownerId         Int
  owner           User     @relation(fields: [ownerId], references: [id])
  total_completed Int?
  booking_ids     Json?
  report_url      String?
  status          String?
  isRead          Boolean  @default(false)
  createdAt       DateTime @default(now())
}

enum Role {
  renter
  car_owner
  admin
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}
